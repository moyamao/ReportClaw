{
  "positive": {
    "0到1": 20
  },
  "negative": {
    "过剩": -10,
    "竞争白热化": -20
  },
  "cagr_rules": [
    {
      "_comment": "同比增长规则：所有命中都落库。公司本体经营增长优先加分；宏观/行业/第三方统计句子记 neutral；费用成本类按负向处理。银行/非银金融等行业可按行业乘数折减分值。",
      "enabled": true,
      "phrase": "同比增长",
      "phrase_patterns": [
        "(?:较|比)?(?:上年|去年)?同期增长",
        "同比增幅"
      ],
      "mode": "linear",
      "k": 0.1,
      "cap": 12,
      "min_pct": 20,
      "window_chars": 120,
      "company_markers": [
        "公司",
        "本公司",
        "本集团",
        "集团公司",
        "母公司"
      ],

      "neutralize_if_contains": [
          "数据显示",
          "统计数据显示",
          "根据",
          "白皮书",
          "研究报告",
          "国家能源局",
          "统计局",
          "海关总署",
          "国家数据局",
          "国家药监局",
          "国家电影局",
          "国家移民管理局",
          "中国汽车工业协会",
          "中国汽车动力电池产业创新联盟",
          "中国半导体行业协会",
          "证券业协会",
          "中关村储能产业技术联盟",
          "乘联会",
          "IDC",
          "Gartner",
          "TrendForce",
          "EVTank",
          "SIA",
          "WSTS",
          "Omdia",
          "GGII",
          "SNEResearch",
          "Sigmaintell",
          "艾瑞咨询",
          "艾媒咨询",
          "奥维云网",
          "全行业",
          "行业总体",
          "行业格局",
          "行业趋势",
          "行业情况",
          "市场规模",
          "市场份额",
          "累计装机",
          "装机容量",
          "累计并网",
          "全国",
          "我国",
          "国内",
          "全球",
          "全省",
          "研发投入",
          "研发费用",
          "研发人员",
          "预算"
      ],

      "negate_if_contains": [
        "销售费用",
        "管理费用",
        "营业成本"
      ],
      "negate_penalty_ratio": 0.5,

      "full_negate_if_contains": [
        "财务费用",
        "减值损失"
      ],
      "industry_multipliers": [
        {
          "industries": [
            "银行I",
            "非银金融I",
            "金融服务I"
          ],
          "multiplier": 0.15
        }
      ]
    },
    {
      "_comment": "同比减少规则：与同比增长规则方向相反，百分比越大扣分越多。",
      "enabled": true,
      "phrase": "同比减少",
      "phrase_patterns": [
        "(?:较|比)?(?:上年|去年)?同期减少",
        "(?:较|比)?(?:上年|去年)?同期下降",
        "(?:较|比)?(?:上年|去年)?同期降低",
        "同比下降",
        "同比降低",
        "同比降幅"
      ],
      "mode": "linear",
      "polarity": "neg",
      "k": 0.1,
      "cap": 6,
      "min_pct": 20,
      "window_chars": 120,
      "company_markers": [],
      "neutralize_if_contains": [
        "销售费用"
      ],
      "negate_if_contains": [],
      "full_negate_if_contains": []
    },
    {
      "_comment": "销售费用同比减少规则：销售费用下降通常代表费用控制改善，按同比减少百分比正向加分，最高按60%封顶加6分。",
      "enabled": true,
      "phrase": "销售费用同比减少",
      "phrase_patterns": [
        "销售费用.{0,40}同比减少",
        "销售费用.{0,40}同比下降",
        "销售费用.{0,40}同比降低",
        "销售费用.{0,40}(?:较|比)?(?:上年|去年)?同期减少",
        "销售费用.{0,40}(?:较|比)?(?:上年|去年)?同期下降",
        "销售费用.{0,40}(?:较|比)?(?:上年|去年)?同期降低"
      ],
      "mode": "linear",
      "polarity": "pos",
      "k": 0.1,
      "cap": 6,
      "min_pct": 20,
      "window_chars": 120,
      "company_markers": [],
      "neutralize_if_contains": [],
      "negate_if_contains": [],
      "full_negate_if_contains": []
    },
    {
      "_comment": "复合增长率规则：当句中出现复合增长率且百分比大于等于15%时，视为行业/赛道未来趋势偏正向；按同比增长逻辑的一半分值计分。该规则当前不做银行/非银金融行业折减。",
      "enabled": true,
      "phrase": "复合增长率",
      "phrase_aliases": [
        "年复合增长率",
        "复合年增长率",
        "年均复合增长率",
        "CAGR"
      ],
      "mode": "linear",
      "k": 0.1,
      "score_multiplier": 0.5,
      "cap": 12,
      "min_pct": 15,
      "window_chars": 120,
      "company_markers": [],
      "neutralize_if_contains": [],
      "negate_if_contains": [],
      "full_negate_if_contains": []
    }
  ]
}
